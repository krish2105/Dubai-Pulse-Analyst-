# Frontend environment (Vite exposes only VITE_* vars to the client).
# Copy to `.env.local` for local dev, or set in Vercel project settings.

# Base URL of the backend API. Leave blank to use same-origin / the Vite dev proxy.
VITE_API_BASE_URL=

# Must match BACKEND_API_KEY on the server (sent as the X-API-Key header).
# Leave blank if the backend has auth disabled.
VITE_API_KEY=
