# ------------------------------------------------------------------ #
# DubaiPulse Analyst — backend environment
# Copy this file to `.env` and fill in the values. NEVER commit `.env`.
# ------------------------------------------------------------------ #

# --- Anthropic (required for the agents to run) ---
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_SQL_MODEL=claude-sonnet-5
LLM_MAX_TOKENS=1500
LLM_TEMPERATURE=0.0

# --- Backend API auth ---
# Any client calling /chat must send this value as the `X-API-Key` header.
# Leave BLANK to disable auth (local dev / CI only).
BACKEND_API_KEY=change-me-to-a-long-random-string

# --- CORS: comma-separated allowed frontend origins ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Rate limiting (slowapi syntax) ---
RATE_LIMIT=20/minute

# --- Query engine safety ---
MAX_RESULT_ROWS=2000

# --- App ---
APP_ENV=development
