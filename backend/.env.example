# ------------------------------------------------------------------ #
# DubaiPulse Analyst — backend environment
# Copy this file to `.env` and fill in the values. NEVER commit `.env`.
# ------------------------------------------------------------------ #

# --- LLM provider ---------------------------------------------------
# Choose ONE: ollama (free/local, no key) | groq (free tier) | gemini (free tier)
#           | openai | anthropic
LLM_PROVIDER=ollama

# Optional model override (blank = provider default):
#   ollama  -> qwen2.5:7b        groq   -> llama-3.3-70b-versatile
#   gemini  -> gemini-2.0-flash  openai -> gpt-4o-mini   anthropic -> claude-sonnet-5
LLM_MODEL=
LLM_MAX_TOKENS=1500
LLM_TEMPERATURE=0.0
LLM_TIMEOUT=180

# --- Provider credentials (only the selected provider's is needed) ---
# Ollama needs NO key. Install from https://ollama.com then: `ollama pull qwen2.5:7b`
OLLAMA_BASE_URL=http://localhost:11434/v1
# Groq  (free): https://console.groq.com/keys
GROQ_API_KEY=
# Gemini (free): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# OpenAI or any OpenAI-compatible base (OpenRouter, Together, …)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# Anthropic: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# --- Backend API auth ---
# Any client calling /chat must send this value as the `X-API-Key` header.
# Leave BLANK to disable auth (local dev / CI only).
BACKEND_API_KEY=

# --- CORS: comma-separated allowed frontend origins (or '*') ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Rate limiting (slowapi syntax) ---
RATE_LIMIT=20/minute

# --- Query engine safety ---
MAX_RESULT_ROWS=2000

# --- App ---
APP_ENV=development
